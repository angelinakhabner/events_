NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/goin
ANTHROPIC_API_KEY=sk-ant-...
# Optional: render venue listing pages through Firecrawl (JS + anti-bot).
# When unset, the scraper uses a plain fetch (default). Enrichment always
# stays on native fetch. Requires egress to api.firecrawl.dev.
FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_API_URL=https://api.firecrawl.dev
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@goin.app
