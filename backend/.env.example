NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/goin
ANTHROPIC_API_KEY=sk-ant-...
# Optional: render venue listing pages through Firecrawl (JS + anti-bot).
# When unset, the scraper uses a plain fetch (default). Enrichment always
# stays on native fetch. Requires egress to api.firecrawl.dev.
FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_API_URL=https://api.firecrawl.dev
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@goin.app
# Scheduled scrape (runs inside the backend process). Off unless enabled.
# SCRAPE_CRON_ENABLED=true
# Hour of day in Europe/Warsaw to run (0-23, default 7).
# SCRAPE_CRON_HOUR=7
# Day of week in Europe/Warsaw (0=Sun … 6=Sat). Unset = daily; set for a
# weekly sweep to save tokens (venues rarely change schedules day-to-day).
# SCRAPE_CRON_DAY_OF_WEEK=1
