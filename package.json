{
  "name": "goin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Goin — customisable cultural events aggregator",
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build",
    "typecheck": "npm --workspace backend run typecheck && npm --workspace frontend run typecheck",
    "lint": "eslint .",
    "test": "npm --workspace backend run test && npm --workspace frontend run test",
    "test:backend": "npm --workspace backend run test",
    "test:frontend": "npm --workspace frontend run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript-eslint": "^8.15.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
